---
import { skillCategories } from "../data/portfolio";
---

<section id="skills" class="mx-auto flex min-h-screen max-w-7xl flex-col justify-center px-5 py-24 sm:px-8">
  <div class="mx-auto mb-10 max-w-3xl text-center">
    <p class="mb-3 text-sm font-semibold uppercase tracking-[0.22em] text-emerald-200">Technical stack</p>
    <h2 class="text-5xl font-bold sm:text-6xl"><span class="gradient-text">My</span> Skills</h2>
    <p class="mt-5 text-zinc-300">A compact view of the technologies I use to build interfaces, services, and computer science projects.</p>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    {skillCategories.map((category) => (
      <article class="glass-panel rounded-2xl p-6">
        <div class="mb-5 flex items-center justify-between gap-4">
          <h3 class="text-2xl font-bold">{category.title}</h3>
          <span class="h-2.5 w-2.5 rounded-full bg-emerald-300 shadow-[0_0_18px_rgba(52,211,153,0.75)]"></span>
        </div>
        <p class="mb-6 min-h-12 text-sm leading-6 text-zinc-400">{category.description}</p>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 lg:grid-cols-2">
          {category.skills.map((skill) => (
            <span class="flex min-h-16 items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.06] px-3 py-3 text-sm font-semibold text-zinc-200 transition hover:border-cyan-300/40 hover:text-cyan-100">
              <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl bg-white/10 text-lg text-cyan-100">
                {skill.icon ? <i class={`bx ${skill.icon}`}></i> : <span class="text-xs font-black">{skill.mark}</span>}
              </span>
              <span>{skill.name}</span>
            </span>
          ))}
        </div>
      </article>
    ))}
  </div>
</section>
