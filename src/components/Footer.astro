---
import { socials } from "../data/portfolio";
---

<footer class="border-t border-white/10 px-5 py-7 sm:px-8">
  <div class="mx-auto flex max-w-7xl flex-col items-center gap-4">
    <div class="flex justify-center gap-5">
      {socials.map((social) => (
        <a
          href={social.href}
          target="_blank"
          rel="noreferrer"
          aria-label={social.label}
          class="flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-white/[0.04] text-3xl text-zinc-300 transition duration-300 hover:scale-110 hover:border-cyan-300/40 hover:text-cyan-100"
        >
          <i class={`bx ${social.icon}`}></i>
        </a>
      ))}
    </div>
    <p class="text-center text-sm text-zinc-400">© 2026 Gean Lima. All rights reserved.</p>
  </div>
</footer>
